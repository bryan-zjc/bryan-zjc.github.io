
@article{zhu_joint_2025,
	title = {Joint Optimization of Multivehicles and Traffic Signal: A Parallel Approach in Spatial Domain},
	volume = {12},
	rights = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/{IEEE}.html},
	issn = {2327-4662, 2372-2541},
	url = {https://ieeexplore.ieee.org/document/11165299/},
	doi = {10.1109/JIOT.2025.3610639},
	shorttitle = {Joint Optimization of Multivehicles and Traffic Signal},
	abstract = {With the emerging Internet of Things ({IoT}) and vehicle-road-cloud integration system ({VRCIS}) technologies, coordinating connected and automated vehicles ({CAVs}) and traﬃc signals is becoming a practical solution to further enhance traﬃc eﬃciency. However, current studies still have limitations. First, there is a domain mismatch between {CAV} trajectory planning and signal optimization. This mismatch requires separate modeling of trajectory planning and signal optimization, which greatly reduces global optimality. Second, previous studies are not applicable to the actual mixed traﬃc environment since they mostly simplify the behavior of human-driven vehicles ({HVs}) without considering queuing and stop-and-go maneuvers. Therefore, we propose a novel multivehicles and signal coordination ({MVSC}) planner to solve the limitations via the following designs: 1) joint optimization is achieved via formulating in the spatial domain, unifying {CAV}’s planning domain with the traﬃc signal optimizing domain; 2) a parallel algorithm is designed for the adaptation to the numbers of {CAVs}; this algorithm is based on alternating direction method of multipliers ({ADMM}), making full use of {IoT} and {VRCIS}; and 3) {HV} queuing and stop-and-go behaviors are considered in our modeling. Simulation results show that the proposed {MVSC} planner can enhance eﬃciency and ecology by 23.60\% and 15.63\%, respectively. At {CAV}’s penetration rate of 40\% and V/C ratio of 0.75, the proposed planner shows its full potential in performance enhancement. The average computation time of the parallel computing approach is only within 10 ms, which conﬁrms the real-time implementation capability.},
	pages = {50912--50927},
	number = {23},
	journaltitle = {{IEEE} Internet of Things Journal},
	shortjournal = {{IEEE} Internet Things J.},
	author = {Zhu, Jichen and Wang, Haoran and Huang, Heye and Yang, Xiaoguang and Tan, Chaopeng and Hu, Jia},
	urldate = {2025-11-21},
	date = {2025-12-01},
	langid = {english},
	file = {PDF:E\:\\Zotero\\storage\\3P3JCRMS\\Zhu 等 - 2025 - Joint Optimization of Multivehicles and Traffic Signal A Parallel Approach in Spatial Domain.pdf:application/pdf},
}
